# ──────────────────────────────────────────────────────────────
# SERVER
# ──────────────────────────────────────────────────────────────
PORT=3000
# "development" enables stack traces in error responses. Use "production" when deployed.
NODE_ENV=development

# ──────────────────────────────────────────────────────────────
# DATABASE
# MongoDB MUST be a replica set (or Atlas) — multi-document
# transactions used for wallet transfers require it.
# Local replica set example: mongodb://127.0.0.1:27017/mini_wallet?replicaSet=rs0
# ──────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/mini_wallet?replicaSet=rs0

# ──────────────────────────────────────────────────────────────
# JWT
# Generate strong secrets, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ──────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_different_long_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ──────────────────────────────────────────────────────────────
# SAFARICOM DARAJA API
# Get these from https://developer.safaricom.co.ke (create an app)
# Sandbox base URL: https://sandbox.safaricom.co.ke
# Production base URL: https://api.safaricom.co.ke
# ──────────────────────────────────────────────────────────────
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret

# Lipa Na M-Pesa Online (STK Push)
MPESA_SHORT_CODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_online_passkey
# Publicly reachable HTTPS URL Safaricom will POST STK results to.
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# B2C (Business to Customer — withdrawals)
MPESA_B2C_URL=/mpesa/b2c/v1/paymentrequest
MPESA_INITIATOR_NAME=your_b2c_initiator_username
# Security credential = your initiator password encrypted with Safaricom's public cert.
# For sandbox you may paste the pre-generated test credential from the portal.
MPESA_INITIATOR_PASSWORD=your_encrypted_security_credential
MPESA_B2C_RESULT_URL=https://your-domain.com/api/mpesa/b2c/result
MPESA_B2C_QUEUE_URL=https://your-domain.com/api/mpesa/b2c/timeout

# ──────────────────────────────────────────────────────────────
# SECURITY
# ──────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed by CORS.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Comma-separated Safaricom source IPs allowed to hit the public callback.
# Leave EMPTY to disable the IP check (e.g. local testing). Populate in production.
SAFARICOM_IP_WHITELIST=196.201.214.200,196.201.214.206,196.201.213.114,196.201.214.207,196.201.214.208,196.201.213.44,196.201.212.127,196.201.212.138,196.201.212.129,196.201.212.136,196.201.212.74,196.201.212.69
